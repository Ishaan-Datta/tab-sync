{
  "name": "wxt-svelte-starter",
  "version": "0.0.1",
  "private": true,
  "description": "manifest.json description",
  "type": "module",
  "scripts": {
    "dev:firefox": "wxt -b firefox",
    "dev:chrome": "wxt -b chrome",
    "build:firefox": "wxt build -b firefox",
    "zip:firefox": "wxt zip -b firefox",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "build:check": "npm run check",
    "lint": "oxlint --fix . && eslint . --fix",
    "lint:check": "oxlint --quiet . && eslint .",
    "fmt": "oxfmt --write . && prettier \"**/*.svelte\" --write --log-level warn",
    "fmt:check": "oxfmt --check . && prettier \"**/*.svelte\" --check --log-level warn",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@tanstack/svelte-virtual": "^3.13.23",
    "dexie": "^4.4.1",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/webextension-polyfill": "^0.12.5",
    "@wxt-dev/module-svelte": "^2.0.4",
    "eslint": "^9.39.2",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^16.4.0",
    "lefthook": "^2.0.16",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.42.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "wxt": "^0.20.20"
  },
  "trustedDependencies": [
    "esbuild",
    "lefthook",
    "spawn-sync"
  ]
}
